# PostgreSQL connection string used by Prisma.
# If your Supabase password contains special characters like [ ] @ or :,
# percent-encode the password portion before pasting it here.
DATABASE_URL="postgresql://postgres.<project_ref>:nexacareproject%40002@<host>:<port>/<database>?pgbouncer=true"
# Two INDEPENDENT secrets, each >= 32 random chars.
# Generate with: openssl rand -base64 48
ACCESS_TOKEN_SECRET="replace-with-32+-char-random-secret"
REFRESH_TOKEN_SECRET="replace-with-a-different-32+-char-random-secret"

# Server-side only. Never prefix with NEXT_PUBLIC_, never add to
# next.config.js `env`/`publicRuntimeConfig` — either would leak it into
# the client bundle the same way the old vite.config.ts `define` block did.
GEMINI_API_KEY="your-gemini-api-key"

NODE_ENV="development"
