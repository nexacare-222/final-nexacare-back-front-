# Where the Next.js backend (nexacare-backend) is running. This server
# proxies every /api/* request there so the browser only ever talks to one
# origin -- required for the backend's SameSite=Strict auth cookies.
BACKEND_ORIGIN="http://localhost:4000"

NODE_ENV="development"

# GEMINI_API_KEY is intentionally NOT here anymore -- it lives only in
# backend/.env.example now. It must never be read by this app or inlined
# into the client bundle again.
